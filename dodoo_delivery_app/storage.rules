rules_version = '2';

// Starter Storage rules for the DoDoo rider app.
// Any signed-in Firebase user can read/write. TODO: tighten before production
// (e.g. a rider may only write under profile_pictures/<uid> and
// rider_documents/<uid>/).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
