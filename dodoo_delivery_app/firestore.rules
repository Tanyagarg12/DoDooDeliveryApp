rules_version = '2';

// Starter rules for the DoDoo rider app migration.
// Any signed-in Firebase user (riders authenticate via phone OTP) can
// read/write. TODO: tighten before production — e.g. riders limited to their
// own rider doc, orders writable only via the accept/status flows, admins via
// custom claims.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
