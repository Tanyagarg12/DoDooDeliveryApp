rules_version = '2';

// DoDoo Firestore rules.
//
// Riders + admin authenticate with Firebase *anonymous* sessions (OTP itself is
// handled by the external DoDoo API). Anonymous sessions can't be told apart,
// so per-rider / role-based access ISN'T enforceable here — that needs real
// Firebase identities (Phone Auth or a custom-token Cloud Function), which were
// deliberately deferred to stay off the Blaze plan.
//
// What these rules DO enforce:
//  • every request must be authenticated (no fully public access), and
//  • core collections can't be DELETED from a client (prevents data wipe-out).
//    Only order_offers may be deleted (the admin re-broadcast flow needs it).
service cloud.firestore {
  match /databases/{database}/documents {

    // Re-broadcast clears & recreates offers, so deletes are allowed here.
    match /order_offers/{id} {
      allow read, write: if request.auth != null;
    }

    // Core data: create/update/read when signed in, but never client-deletable.
    match /riders/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
    // Stores/merchants — same policy as riders (approval is enforced app-side
    // for now; see firestore.rules.proposed for the admin-only hardening).
    match /stores/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;

      // A store's menu (items + prices). Subcollections need their own rule —
      // the parent match does not cascade. Menu items may be deleted (the store
      // manages its own catalog).
      match /menu/{itemId} {
        allow read, write: if request.auth != null;
      }
      // Bank accounts for payouts
      match /bank_accounts/{id} {
        allow read, create, update, delete: if request.auth != null;
      }
    }
    match /orders/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
    match /withdrawal_requests/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
    match /wallet_transactions/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
    match /store_wallet_transactions/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
    match /stores/{storeId}/withdrawal_requests/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
    match /rider_tracking/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
    match /app_settings/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
    match /support_tickets/{id} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }

    // Anything not matched above is denied by default.
  }
}
