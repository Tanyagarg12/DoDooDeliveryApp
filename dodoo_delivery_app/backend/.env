DJANGO_ENV=local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,0.0.0.0,192.168.1.11
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.11:3000,http://192.168.1.11:8000

# ── Neon PostgreSQL (production) ────────────────────────────────────────────
# 1. Sign up at https://neon.tech  →  create a project  →  copy connection string
# 2. Paste the postgresql://... URL below (leave blank to use local SQLite)
DATABASE_URL=

POSTGRES_DB=dodoo_dispatch
POSTGRES_USER=dodoo
POSTGRES_PASSWORD=dodoo_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
